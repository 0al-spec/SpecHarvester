  "selectionPolicy": {
    "mayEnterSelectedHandoffWhen": [
      "currentClassification is no longer needs_regeneration",
      "handoffStatus is selected_candidate_ready",
      "all required evidence roles for the blocker class are present",
      "producer preflight status is passed with zero warnings and zero errors",
      "static viewer status is ok",
      "registryAcceptanceDecision.status remains external_required",
      "preview_only is preserved until SpecPM maintainer acceptance"
    ],
    "mustRemainDeferredWhen": [
      "package-set identity remains missing",
      "warning-bearing enrichment evidence is unresolved",
      "package id normalization or identity drift is unresolved",
      "producer preflight has warnings or errors",
      "static viewer output is missing",
      "operator cannot point to regenerated evidence digests"
    ]
